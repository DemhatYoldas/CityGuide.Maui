<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CityGuide.Maui.Views.WelcomePage"
             Title="WelcomePage">

    <Grid RowDefinitions="Auto, *">

        <!-- ============ HEADER ============ -->
        <Grid Grid.Row="0"
              HeightRequest="64"
              ColumnDefinitions="*, Auto"
              Padding="20,0"
              BackgroundColor="#F8F9FA">

            <!-- Kolon 0: Marka adı (sola yaslı) -->
            <Label Grid.Column="0"
                   Text="Milano Şehir Rehberi"
                   TextColor="#0D47A1"
                   FontSize="22"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   HorizontalOptions="Start" />

            <!-- Kolon 1: Dil ikonu (sağa yaslı) -->
            <Label Grid.Column="1"
                   Text="🌐"
                   FontSize="22"
                   VerticalOptions="Center"
                   HorizontalOptions="End" />

        </Grid>

        <!-- ============ SCROLL EDEN ALAN ============ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- HERO -->
                <BoxView HeightRequest="400" Color="#D4AF37" />

                <!-- CONTENT -->
                <VerticalStackLayout Padding="20,24" Spacing="16">

                    <Label Text="Duomo'nun gotik ihtişamından Brera'nın gizli avlularına kadar Milano'yu gerçek bir yerli gibi keşfedin. Özenle seçilmiş mimari, dünya standartlarında lezzetler ve İtalyan yaşam tarzının zarafetini deneyimleyin."
           TextColor="#455A64"
           FontSize="16"
           LineHeight="1.4" />

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="16">

                        <!-- Kart 1: Seçkin Sanat -->
                        <Border Grid.Column="0"
            Stroke="#C3C6D4"
            StrokeThickness="1"
            BackgroundColor="#F3F4F5"
            Padding="16"
            StrokeShape="RoundRectangle 12">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="🏛" FontSize="22" TextColor="#0D47A1" VerticalOptions="Center" />
                                <Label Text="Seçkin Sanat" FontSize="14" TextColor="#191C1D" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Kart 2: Seçkin Lezzetler -->
                        <Border Grid.Column="1"
            Stroke="#C3C6D4"
            StrokeThickness="1"
            BackgroundColor="#F3F4F5"
            Padding="16"
            StrokeShape="RoundRectangle 12">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="🍽" FontSize="22" TextColor="#0D47A1" VerticalOptions="Center" />
                                <Label Text="Seçkin Lezzetler" FontSize="14" TextColor="#191C1D" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>

                    </Grid>


                </VerticalStackLayout>

                <!-- AUTH CARD -->
                <BoxView HeightRequest="350" Color="#455A64" />

                <!-- FOOTER -->
                <VerticalStackLayout Padding="20,24" Spacing="16">

                    <BoxView HeightRequest="1"
             Color="#C3C6D4"
             HorizontalOptions="Fill" />

                    <!-- Telif sol, linkler sağ: Grid ile iki uca yaslama -->
                    <Grid ColumnDefinitions="*, Auto">

                        <!-- Sol: telif metni -->
                        <Label Grid.Column="0"
               Text="2026 Milano Şehir Rehberi. Tüm hakları saklıdır."
               TextColor="#737783"
               FontSize="12"
               VerticalOptions="Center" />

                        <!-- Sağ: linkler yan yana -->
                        <HorizontalStackLayout Grid.Column="1" Spacing="24">
                            <Label Text="Explore" TextColor="#737783" FontSize="12" />
                            <Label Text="Concierge" TextColor="#737783" FontSize="12" />
                            <Label Text="Stay" TextColor="#737783" FontSize="12" />
                        </HorizontalStackLayout>

                    </Grid>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>